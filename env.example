# ============================================================
# CloudBridge — Environment Variables Template
# ============================================================
#
# SETUP:
#   Windows PowerShell:  cp .env.example .env or copy .env.example .env
#   macOS / Linux:       cp .env.example .env
#
# FILL IN YOUR VALUES in .env
# NEVER commit .env — it is gitignored
# This .env.example IS committed — it shows what is needed
# without exposing real values
#
# ============================================================


# ============================================================
# APP CONFIG
# ============================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# JWT secret for API authentication
# Generate on Node.js 19+ (including Node.js 24):
#   node -e "console.log(crypto.randomBytes(64).toString('hex'))"
#
# crypto is globally available in Node.js 19+ — no import needed
JWT_SECRET=your-jwt-secret-here-minimum-32-characters

# API Key for simple key-based auth (optional)
API_KEY=your-api-key-here

# Log format — 'pretty' for local dev, 'json' for production
LOG_FORMAT=pretty


# ============================================================
# AWS — CHOOSE ONE AUTH METHOD, comment out the others
# ============================================================

# --- Method 1: IAM Role (recommended for EC2 / ECS / Lambda) ---
# No credentials needed — auto-detected from instance metadata
# Only the region is required:
AWS_REGION=ap-south-1

# --- Method 2: AssumeRole via STS ---
# AWS_REGION=ap-south-1
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/cloudbridge-role
# AWS_ROLE_SESSION_NAME=cloudbridge-session
# AWS_EXTERNAL_ID=optional-external-id-for-cross-account

# --- Method 3: Access Key + Secret (local dev only) ---
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# --- Method 4: OIDC / Web Identity (GitHub Actions, Kubernetes) ---
# AWS_REGION=ap-south-1
# AWS_WEB_IDENTITY_TOKEN_FILE=/var/run/secrets/token
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/cloudbridge-oidc-role


# ============================================================
# AZURE — CHOOSE ONE AUTH METHOD
# ============================================================

# --- Method 1: Managed Identity (recommended for Azure infra) ---
# No credentials needed — auto-detected from Azure IMDS
# Only the storage account name is required:
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
# AZURE_CLIENT_ID=optional-only-for-user-assigned-managed-identity

# --- Method 2: Service Principal + Client Secret ---
# AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# --- Method 3: Service Principal + Certificate ---
# AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_CERTIFICATE_PATH=./secrets/azure-sp-cert.pem

# --- Method 4: Connection String (local dev only) ---
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...


# ============================================================
# GCP — CHOOSE ONE AUTH METHOD
# ============================================================

GCP_PROJECT_ID=your-gcp-project-id

# --- Method 1: Service Account Key File (local dev) ---
# Path to the JSON key file inside the secrets/ folder
GCP_KEY_FILE=./secrets/gcp-service-account.json

# --- Method 2: Workload Identity Federation (GKE / Kubernetes) ---
# No file needed — uncomment and set the env var GCP uses automatically:
# GOOGLE_APPLICATION_CREDENTIALS=/var/run/secrets/token

# --- Method 3: Application Default Credentials (local dev alternative) ---
# Run once in terminal: gcloud auth application-default login
# Then comment out GCP_KEY_FILE above — ADC is detected automatically


# ============================================================
# REDIS — for rate limiting
# Optional in development (falls back to in-memory)
# Required in production (in-memory does not work across instances)
# ============================================================

# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=


# ============================================================
# VAULT — HashiCorp Vault
# Production only — not needed for local development
# ============================================================

# VAULT_ADDR=https://vault.yourcompany.com
# VAULT_TOKEN=your-vault-token
# VAULT_NAMESPACE=cloudbridge/
# VAULT_MOUNT_PATH=secret


# ============================================================
# OBSERVABILITY
# ============================================================

# OpenTelemetry collector endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=cloudbridge-middleware
